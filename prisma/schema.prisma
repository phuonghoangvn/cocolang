generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  UX_ENGLISH
  SWEDISH
}

enum Level {
  A1
  A2
  B1
  B2
  C1
}

enum TaskType {
  LISTEN
  SPEAK
  READ
  WRITE
  QUIZ
}

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  password          String         
  name              String?
  avatar            String?        // emoji avatar
  isBot             Boolean        @default(false)
  totalXp           Int            @default(0)
  weeklyXp          Int            @default(0)
  currentStreak     Int            @default(0)
  lastCompletedDate DateTime?

  // Survey / onboarding
  surveyCompleted   Boolean        @default(false)
  nativeLanguage    String?        // e.g. "Vietnamese"
  learningGoal      String?        // e.g. "Work abroad", "Travel", etc.
  currentLevel      String?        // Self-assessed level
  dailyGoalMinutes  Int?           @default(15)
  goalDeadlineDays  Int?           @default(30) // How many days to reach target
  activeTrack       Category       @default(UX_ENGLISH)

  // Email notifications
  emailReminders    Boolean        @default(true)

  progress          UserProgress[]
  enrollments       CourseEnrollment[]
}

model Task {
  id          String         @id @default(cuid())
  category    Category
  level       Level
  day         Int            
  type        TaskType
  title       String
  content     String         
  reference   String?        
  xpReward    Int            @default(100)
  progress    UserProgress[]
}

model UserProgress {
  id            String   @id @default(cuid())
  userId        String
  taskId        String
  userContent   String?  
  isCompleted   Boolean  @default(false)
  completedAt   DateTime @default(now())
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId]) 
}

// Per-course enrollment with customized goals
model CourseEnrollment {
  id               String   @id @default(cuid())
  userId           String
  category         Category
  learningGoal     String?  // e.g. "work", "travel", "culture"
  currentLevel     String?  // Starting level e.g. "B1"
  targetLevel      String?  // Desired level e.g. "C1"
  goalDeadlineDays Int      @default(30)
  enrolledAt       DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}
